# Copy this file to .env, then fill real values.
# Never commit .env to GitHub.

# Gmail account used to send booking notifications.
# Create an app password at https://myaccount.google.com/apppasswords
GMAIL_USER=email_cua_ban@gmail.com
GMAIL_APP_PASSWORD=
NOTIFY_TO=email_nhan_thong_bao@gmail.com

# Fixed secret for admin login sessions. Use a long random string.
SESSION_SECRET=

# Supabase/Postgres connection string.
DATABASE_URL=postgresql://postgres.xxxxx:mat_khau@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Supabase uses SSL. Set DB_SSL=false only for local Postgres.
# DB_SSL=false

# Render/Railway usually sets PORT automatically.
# PORT=3000

# Allow other devices on the same Wi-Fi/LAN to access this server locally.
HOST=0.0.0.0
